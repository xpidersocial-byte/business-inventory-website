<!DOCTYPE html>
<html lang="en" data-theme="facebook">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{% endblock %} | {{ site_config.business_name }}</title>
    <link rel="icon" type="image/webp" href="{{ url_for('static', filename='images/login_hero.webp') }}">

    <!-- UI Frameworks -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --sidebar-width: 240px;
            --primary-gradient: linear-gradient(135deg, #1877f2 0%, #166fe5 100%);
            --glass-bg: rgba(0, 0, 0, 0.05);
            --card-bg: #ffffff;
            --sidebar-bg: #f5f6f7;
            --content-bg: #f0f2f5;
            --text-main: #1c1e21;
            --text-theme-muted: #65676b;
            --primary-soft: #1877f2;
            --border-soft: #ced0d4;
            --scrollbar-thumb: rgba(0, 0, 0, 0.2);
            --navbar-height: 56px;
            --navbar-bg: #1877f2;
            --navbar-text: #ffffff;
        }

        /* Smooth UI Transitions */
        .btn,
        .card,
        .form-control,
        .form-select,
        .dropdown-item,
        .alert-summary-card,
        .category-tile {
            transition: all 0.3s ease;
        }

        .btn:hover {
            transform: translateY(-1px);
        }

        tbody tr {
            transition: background-color 0.2s ease;
        }
